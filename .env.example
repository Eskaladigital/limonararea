# Supabase (obtener en: Dashboard → Project Settings → API)
# La URL debe empezar por https:// (ej: https://tu-proyecto.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Redsys (TPV)
REDSYS_MERCHANT_CODE=your_merchant_code
REDSYS_TERMINAL=001
REDSYS_SECRET_KEY=your_redsys_secret_key
NEXT_PUBLIC_REDSYS_MERCHANT_CODE=your_merchant_code

# Email (Resend)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@tudominio.com
COMPANY_EMAIL=reservas@tudominio.com
INFO_EMAIL=info@tudominio.com
# Para componentes cliente (emails en header, ventas, etc.)
NEXT_PUBLIC_COMPANY_EMAIL=reservas@tudominio.com
NEXT_PUBLIC_INFO_EMAIL=info@tudominio.com

# OpenAI (para generación de contenido)
OPENAI_API_KEY=your_openai_api_key

# Calendar Subscription Token (para sincronización de calendario)
# Este token protege el endpoint de suscripción al calendario
# Cambia este valor por un token seguro y compártelo solo con tu equipo
CALENDAR_SUBSCRIPTION_TOKEN=your_secure_token
NEXT_PUBLIC_CALENDAR_TOKEN=your_secure_token

# App URL
NEXT_PUBLIC_APP_URL=https://www.tudominio.com
